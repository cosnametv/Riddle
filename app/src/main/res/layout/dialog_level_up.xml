<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="24dp"
    app:cardElevation="16dp"
    android:background="#00000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/game_bg_gradient">

        <!-- Glowing Trophy Icon -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_bg_circle"
                android:alpha="0.50"
                app:tint="#FFD700" />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trophy"
                app:tint="#FFD700"
                android:elevation="8dp" />
        </FrameLayout>

        <!-- Level Up Title -->
        <TextView
            android:id="@+id/levelUpTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL UP!"
            android:textSize="32sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:fontFamily="@font/roboto_condensed_light"
            android:shadowColor="#000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:layout_marginBottom="8dp" />

        <!-- Level Message -->
        <TextView
            android:id="@+id/levelUpMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You reached Level X!"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle/Encouragement -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keep going, champion!"
            android:textSize="16sp"
            android:textColor="#B3FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Continue Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/levelUpOkButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continue"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            app:backgroundTint="#3A7BFF"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_next"
            app:iconTint="#FFFFFF"
            app:iconPadding="8dp"
            app:iconGravity="textEnd"
            android:stateListAnimator="@animator/button_elevation"
            android:elevation="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
