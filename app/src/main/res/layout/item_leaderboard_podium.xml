<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="@drawable/normal_item_background2">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 Top Players"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="24dp"
        android:gravity="center"/>

    <!-- 1st Place (Gold) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/gold_gradient">

            <!-- Position Badge -->
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="1"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"
                android:textColor="@color/white"
                android:background="@drawable/circle_gold"
                android:layout_marginEnd="16dp"/>

            <!-- Trophy Icon -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_trophy_gold"
                android:layout_marginEnd="16dp"
                android:contentDescription="1st Place Trophy"/>

            <TextView
                android:id="@+id/firstName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Champion"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:gravity="center_vertical|start"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/firstScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9999"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center_vertical|end"
                android:background="@drawable/score_badge_gold"
                android:padding="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 2nd Place (Silver) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/silver_gradient">

            <!-- Position Badge -->
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="2"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:textColor="@color/white"
                android:background="@drawable/circle_silver"
                android:layout_marginEnd="16dp"/>

            <!-- Trophy Icon -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_trophy_silver"
                android:layout_marginEnd="16dp"
                android:contentDescription="2nd Place Trophy"/>

            <TextView
                android:id="@+id/secondName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runner Up"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:gravity="center_vertical|start"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/secondScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8888"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="center_vertical|end"
                android:background="@drawable/score_badge_silver"
                android:padding="6dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3rd Place (Bronze) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/bronze_gradient">

            <!-- Position Badge -->
            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="3"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="@color/white"
                android:background="@drawable/circle_bronze"
                android:layout_marginEnd="16dp"/>

            <!-- Trophy Icon -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_trophy_bronze"
                android:layout_marginEnd="16dp"
                android:contentDescription="3rd Place Trophy"/>

            <TextView
                android:id="@+id/thirdName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Third Place"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:gravity="center_vertical|start"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/thirdScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7777"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="center_vertical|end"
                android:background="@drawable/score_badge_bronze"
                android:padding="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>